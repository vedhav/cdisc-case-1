{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appsilon.com/synthsdtm/study_config.schema.json",
  "title": "synthsdtm study_config",
  "description": "Structural inputs + rate knobs that fix the shape of the generated SDTM datasets. This is the Stage-4 output contract: a USDM + BC-match document is mapped into a document conforming to this schema, then build_spec()/simulate_sdtm() consume it. See SDTM-INPUTS-AND-TEST-CASES.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["studyId", "design", "cohorts", "demographics", "visitGrid", "domains"],
  "properties": {
    "studyId": {"type": "string", "minLength": 1, "description": "STUDYID anchor (NCT id or sponsor id)."},
    "sponsorStudyId": {"type": "string"},
    "design": {"enum": ["parallel", "crossover", "single-group"]},
    "studyStart": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "country": {"type": "string", "description": "ISO-3166 alpha-3 country code (DM.COUNTRY, CT C66786)."},
    "sites": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "route": {"type": "string", "description": "Default route of administration (CT C66729)."},
    "enrollmentWindowDays": {"type": "integer", "minimum": 0},
    "screenLagDays": {"$ref": "#/$defs/intPair"},

    "cohorts": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["armcd", "arm", "n", "treatments"],
        "properties": {
          "armcd": {"type": "string", "minLength": 1},
          "arm": {"type": "string", "minLength": 1},
          "n": {"type": "integer", "minimum": 1},
          "treatments": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    },

    "demographics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ageRange", "sexes", "races", "ethnicities", "heightCm", "weightKg"],
      "properties": {
        "ageRange": {"$ref": "#/$defs/numPair"},
        "ageUnit": {"type": "string"},
        "sexes": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "races": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "ethnicities": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "heightCm": {"$ref": "#/$defs/numPair"},
        "weightKg": {"$ref": "#/$defs/numPair"}
      }
    },

    "periods": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "startOffset", "endOffset", "visitNum", "epoch"],
        "properties": {
          "label": {"type": "string"},
          "startOffset": {"type": "integer"},
          "endOffset": {"type": "integer"},
          "visitNum": {"type": "number"},
          "epoch": {"type": "string"}
        }
      }
    },

    "visitGrid": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "dayOffset", "visitNum", "epoch"],
        "properties": {
          "label": {"type": "string"},
          "dayOffset": {"type": "integer"},
          "visitNum": {"type": "number"},
          "epoch": {"type": "string"}
        }
      }
    },

    "knobs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Realism rate parameters. Unknown keys are rejected so a typo'd knob fails fast instead of silently defaulting.",
      "properties": {
        "discontinuationRate": {"type": "number", "minimum": 0, "maximum": 1},
        "discoReason": {
          "type": "object", "additionalProperties": false,
          "required": ["decod", "term"],
          "properties": {"decod": {"type": "string"}, "term": {"type": "string"}}
        },
        "discoEndOffsetDays": {"$ref": "#/$defs/intPair"},
        "completionOffsetDays": {"type": "integer"},
        "aeIncidence": {"type": "number", "minimum": 0, "maximum": 1},
        "aeEventsPerSubject": {"$ref": "#/$defs/intPair"},
        "aeSeverityWeights": {"type": "array", "items": {"type": "number"}},
        "aeRelChoices": {"type": "array", "items": {"type": "string"}},
        "aeActnWeights": {"type": "array", "items": {"type": "number"}},
        "conmedPrevalence": {"type": "number", "minimum": 0, "maximum": 1},
        "comorbidityCount": {"$ref": "#/$defs/intPair"},
        "ieExceptionCount": {"type": "integer", "minimum": 0}
      }
    },

    "sourceActivities": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["activityId", "protocolPage"],
          "properties": {
            "activityId": {"type": "string"},
            "activityName": {"type": "string"},
            "bcNcit": {"type": ["string", "null"]},
            "protocolPage": {"type": ["integer", "null"]}
          }
        }
      }
    },

    "domains": {
      "type": "object",
      "minProperties": 1,
      "description": "Map of in-scope SDTM domain code -> domain config. Each declares a builder; the generic 'findings' builder needs a tests[] panel.",
      "additionalProperties": {
        "type": "object",
        "required": ["builder"],
        "properties": {
          "builder": {"enum": ["dm", "ie", "mh", "findings", "ex", "cm", "ae", "ds"]},
          "tests": {"type": "array", "items": {"$ref": "#/$defs/findingTest"}},
          "exceptions": {"type": "array"},
          "openOutcome": {"type": "string"}
        },
        "allOf": [
          {
            "if": {"properties": {"builder": {"const": "findings"}}},
            "then": {"required": ["tests"]}
          }
        ]
      }
    }
  },

  "$defs": {
    "intPair": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
    "numPair": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
    "findingTest": {
      "type": "object",
      "required": ["testcd", "test", "occursAt"],
      "properties": {
        "testcd": {"type": "string", "minLength": 1},
        "test": {"type": "string", "minLength": 1},
        "unit": {"type": "string"},
        "category": {"type": "string"},
        "specimen": {"type": "string"},
        "pos": {"type": "string"},
        "fast": {"enum": ["Y", "N"]},
        "low": {"type": ["number", "null"]},
        "high": {"type": ["number", "null"]},
        "refLow": {"type": ["number", "null"]},
        "refHigh": {"type": ["number", "null"]},
        "decimals": {"type": ["integer", "null"]},
        "subjectAttr": {"type": "string"},
        "occursAt": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "sourceActivity": {"type": "string"},
        "bcNcit": {"type": ["string", "null"]},
        "datasetSpecialization": {"type": "string"}
      }
    }
  }
}
