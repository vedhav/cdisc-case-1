                "type": {
                  "code": null,
                  "codeSystem": "NCIt",
                  "decode": "Experimental"
                }
              },
              {
                "id": "ARM_3",
                "name": "Cohort 3",
                "description": "Participants will be randomised in a ratio of 1:1 to receive placebo and prednisolone over two 72 hour periods in a cross over design (placebo followed by 5 mg prednisolone \\[AB sequence group\\] or 5 mg prednisolone followed by placebo \\[BA sequence group\\]).",
