  "eligibilityCriteria": [
    {
      "id": "EC_INC_1",
      "category": "Inclusion",
      "identifier": "INC1",
      "text": "Participants with diagnosis of T2DM for 6 months prior to screening: HbA1c in the diabetes range or fasting plasma glucose 126 -220 mg/dL."
    },
    {
      "id": "EC_INC_2",
      "category": "Inclusion",
      "identifier": "INC2",
      "text": "On stable metformin therapy for at least 4 weeks, where no significant dose change (increase or decrease ≥ 500 mg/day) has occurred prior to screening and HbA1c 6% - 9.5%, or on dual therapy with metformin in combination with SGLT2i or DPP4i and HbA1c 6% - 8%. Participants on dual therapy will require 2 weeks wash-out of SGLT2i or DPP4i."
    },
    {
      "id": "EC_INC_3",
      "category": "Inclusion",
      "identifier": "INC3",
      "text": "Venous access suitable for multiple cannulations"
    },
    {
      "id": "EC_INC_4",
      "category": "Inclusion",
      "identifier": "INC4",
      "text": "Contraceptive use by men should be consistent with local regulations regarding the methods of contraception for those participating in clinical studies."
    },
    {
      "id": "EC_INC_5",
      "category": "Inclusion",
      "identifier": "INC5",
      "text": "Female participants must be not lactating and not of childbearing potential."
    },
    {
      "id": "EC_INC_6",
      "category": "Inclusion",
      "identifier": "INC6",
      "text": "If sexually active, nonsterilized males who have a female partner of childbearing potential must practice effective contraceptive measures."
    },
    {
      "id": "EC_INC_7",
      "category": "Inclusion",
      "identifier": "INC7",
      "text": "Capable of giving signed informed consent."
    },
    {
      "id": "EC_INC_8",
      "category": "Inclusion",
      "identifier": "INC8",
      "text": "Provision of informed consent prior to any study specific procedures."
    },
    {
      "id": "EC_EXC_1",
      "category": "Exclusion",
      "identifier": "EXC1",
      "text": "History or presence of type 1 diabetes."
    },
    {
      "id": "EC_EXC_2",
      "category": "Exclusion",
      "identifier": "EXC2",
      "text": "History of severe hypoglycaemia or hypoglycaemia unawareness within the last 6 months."
    },
    {
      "id": "EC_EXC_3",
      "category": "Exclusion",
      "identifier": "EXC3",
      "text": "History or presence of diabetic foot ulcers"
    },
    {
      "id": "EC_EXC_4",
      "category": "Exclusion",
      "identifier": "EXC4",
      "text": "Participants with advanced diabetic complications."
    },
    {
      "id": "EC_EXC_5",
      "category": "Exclusion",
      "identifier": "EXC5",
      "text": "History of clinically significant lactic acidosis or ketoacidosis following diagnosis with T2DM."
    },
    {
      "id": "EC_EXC_6",
      "category": "Exclusion",
      "identifier": "EXC6",
      "text": "History of, or known significant infection or positivity at Visit 1, including hepatitis A, B, or C, HIV, tuberculosis that may put the participant at risk during participation in the study."
    },
    {
      "id": "EC_EXC_7",
      "category": "Exclusion",
      "identifier": "EXC7",
      "text": "History and / or presence of COVID-19."
    },
    {
      "id": "EC_EXC_8",
      "category": "Exclusion",
      "identifier": "EXC8",
      "text": "Donation of blood (≥ 450 mL) within 3 months or donation of plasma within 14 days before Visit 1."
    },
    {
      "id": "EC_EXC_9",
      "category": "Exclusion",
      "identifier": "EXC9",
      "text": "History of or current alcohol or drug abuse (including marijuana), as judged by the investigator."
    },
    {
      "id": "EC_EXC_10",
      "category": "Exclusion",
      "identifier": "EXC10",
      "text": "Previous psychiatric disorders."
    },
    {
      "id": "EC_EXC_11",
      "category": "Exclusion",
      "identifier": "EXC11",
      "text": "Any latent, acute, or chronic infections or at risk of infection, or history of skin abscesses within 90 days prior to the first administration of investigational medicinal product (IMP) at the discretion of the investigator."
    },
    {
      "id": "EC_EXC_12",
      "category": "Exclusion",
      "identifier": "EXC12",
      "text": "History of adrenal insufficiency."
    },
    {
      "id": "EC_EXC_13",
      "category": "Exclusion",
      "identifier": "EXC13",
      "text": "History or current inflammatory disorder."
    },
    {
      "id": "EC_EXC_14",
      "category": "Exclusion",
      "identifier": "EXC14",
      "text": "Any other condition that, in the opinion of the investigator, would interfere with evaluations of the IMP or interpretation of participant safety or study results."
    },
    {
      "id": "EC_EXC_15",
      "category": "Exclusion",
      "identifier": "EXC15",
      "text": "History of severe allergy/hypersensitivity to AZD9567 or any of the excipients of the product, or ongoing clinically important allergy/hypersensitivity as judged by the investigator."
    },
    {
      "id": "EC_EXC_16",
      "category": "Exclusion",
      "identifier": "EXC16",
      "text": "Oral or parenteral steroids 8 weeks prior to randomisation and during the study. Topical and inhaled steroids 4 weeks prior to randomisation are acceptable."
    },
    {
      "id": "EC_EXC_17",
      "category": "Exclusion",
      "identifier": "EXC17",
      "text": "Use of any prohibited medication during the study or if the required washout time of such medication was not adhered to."
    },
    {
      "id": "EC_EXC_18",
      "category": "Exclusion",
      "identifier": "EXC18",
      "text": "Receipt of live or live attenuated vaccine within 4 weeks prior to the first administration of IMP."
    },
    {
      "id": "EC_EXC_19",
      "category": "Exclusion",
      "identifier": "EXC19",
      "text": "Planned in-patient surgery, major dental procedure, or hospitalisation during the study."
    },
    {
      "id": "EC_EXC_20",
      "category": "Exclusion",
      "identifier": "EXC20",
      "text": "Previous participation or participation in any other research study within 1 month prior to Visit 1."
    },
    {
      "id": "EC_EXC_21",
      "category": "Exclusion",
      "identifier": "EXC21",
      "text": "Patient treated with any investigational drug within 30 days (or 5 half-lives, whichever is longer) prior to Visit 1."
    },
    {
      "id": "EC_EXC_22",
      "category": "Exclusion",
      "identifier": "EXC22",
      "text": "Uncontrolled hypertension (BP \\> 160 mmHg systolic or \\> 95 mmHg diastolic)."
    },
    {
      "id": "EC_EXC_23",
      "category": "Exclusion",
      "identifier": "EXC23",
      "text": "Diagnosis of heart failure and current symptoms regardless of definition, ie, HfpEF, HfrEF."
    },
    {
      "id": "EC_EXC_24",
      "category": "Exclusion",
      "identifier": "EXC24",
      "text": "Acute coronary syndrome / unstable angina, coronary intervention procedures (percutaneous coronary intervention or coronary artery bypass graft) within the past 6 months."
    },
    {
      "id": "EC_EXC_25",
      "category": "Exclusion",
      "identifier": "EXC25",
      "text": "Stroke within the past 3 months."
    },
    {
      "id": "EC_EXC_26",
      "category": "Exclusion",
      "identifier": "EXC26",
      "text": "QTcF \\> 470 ms or family history of long QT-syndrome."
    },
    {
      "id": "EC_EXC_27",
      "category": "Exclusion",
      "identifier": "EXC27",
      "text": "AV-block II-III or sinus node dysfunction with significant pause, not treated with pacemaker."
    }
  ],
  "objectives": [
    {
      "id": "OBJ1",
      "level": "Primary",
      "text": "Assess the effect on glycaemic control of AZD9567 (glucose AUC(0-4) vs baseline following standardised MMTT) compared to prednisolone in adults with T2DM.",
      "endpoints": [
        {
          "id": "EP1",
          "level": "Primary",
          "text": "Change From Baseline in Glucose Area Under the Plasma Concentration Versus Time Curve From Zero to 4 Hours Post-dose AUC(0-4)"
        }
      ]
    },
    {
      "id": "OBJ2",
      "level": "Secondary",
      "text": "Evaluate safety, tolerability and pharmacokinetics of AZD9567.",
      "endpoints": [
        {
          "id": "EP_S1",
          "level": "Secondary",
          "text": "Mean Glucose Level as Determined Via the Continuous Glucose Monitoring (CGM) System"
        },
        {
          "id": "EP_S2",
          "level": "Secondary",
          "text": "Rise in Mean Glucose Levels Over 24-hour Periods From Start of IMP Dosing"
        },
        {
          "id": "EP_S3",
          "level": "Secondary",
          "text": "Change From Baseline in Fasting Glucose"
        },
        {
          "id": "EP_S4",
          "level": "Secondary",
          "text": "Change From Baseline AUC(0-4) on Hormones Related to Glucose Homeostasis (Insulin)"
        },
        {
          "id": "EP_S5",
          "level": "Secondary",
          "text": "Change From Baseline AUC(0-4) on Hormones Related to Glucose Homeostasis (Glucagon)"
        },
        {
          "id": "EP_S6",
          "level": "Secondary",
          "text": "Change From Baseline AUC(0-4) on Hormones Related to Glucose Homeostasis (Glucagon-like Peptide-1 [GLP-1])"
        }
      ]
    }
  ]
}