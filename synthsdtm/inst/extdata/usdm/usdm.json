                "id": "ARM_1",
                "name": "Cohort 1",
                "description": "Participants will be randomised in a ratio of 1:1 to receive AZD9567 and prednisolone over two 72 hour periods in a cross over design (72 mg AZD9567 followed by 40 mg prednisolone \\[AB sequence group\\] or 40 mg prednisolone followed by 72 mg AZD9567 \\[BA sequence group\\]).",
                "type": {
                  "code": null,
                  "codeSystem": "NCIt",
                  "decode": "Experimental"
                }
              },
              {
                "id": "ARM_2",
                "name": "Cohort 2",
